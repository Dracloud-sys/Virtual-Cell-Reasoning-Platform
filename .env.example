# Copy to .env and adjust. All values are optional in v0.1 (in-memory backend by default).

# Knowledge base backend: memory | neo4j
VCELL_KNOWLEDGE_BACKEND=memory

# Neo4j (graph backend)
VCELL_NEO4J_URI=bolt://localhost:7687
VCELL_NEO4J_USER=neo4j
VCELL_NEO4J_PASSWORD=changeme

# Qdrant (vector backend)
VCELL_QDRANT_URL=http://localhost:6333

# PostgreSQL (run/experiment metadata)
VCELL_POSTGRES_DSN=postgresql://vcell:vcell@localhost:5432/vcell

# API
VCELL_API_HOST=0.0.0.0
VCELL_API_PORT=8000

# Logging
VCELL_LOG_LEVEL=INFO
